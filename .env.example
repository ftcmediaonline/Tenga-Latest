# Public site URL (used for Open Graph / Twitter link previews — set to your production URL at build time)
# Production site (auth email links + OG tags). Must match Supabase Auth → Site URL.
VITE_SITE_URL=https://tengavm.co.zw

# Supabase — get these from your project: Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Email (Edge Functions only — set in Supabase Dashboard → Project Settings → Edge Functions → Secrets)
# TRANSACTIONAL_FROM_EMAIL=Tenga Virtual Mall <info@tengavm.co.zw>
# PROMO_FROM_EMAIL=Tenga Virtual Mall <info@tengavm.co.zw>
# RESEND_API_KEY=re_...
# SITE_URL=https://your-production-domain.com
