# Public site URL (auth email links, OG tags, payment redirects). Must match Supabase Auth → Site URL.
VITE_SITE_URL=https://tengavm.co.zw

# Supabase — Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# --- Supabase Edge Function secrets (Dashboard → Project Settings → Edge Functions → Secrets) ---

# Email (Resend)
# RESEND_API_KEY=re_...
# TRANSACTIONAL_FROM_EMAIL=Tenga Virtual Mall <info@tengavm.co.zw>
# PROMO_FROM_EMAIL=Tenga Virtual Mall <info@tengavm.co.zw>
# MASTER_ADMIN_EMAIL=admin@tengavm.co.zw
# SITE_URL=https://tengavm.co.zw

# iVeri Lite payment gateway (iveri-gateway Edge Function)
# Zimbabwe / Nedbank merchants typically use nedsecure; confirm with your acquirer.
# IVERI_LITE_APPLICATION_ID={YOUR-GUID-FROM-BACKOFFICE}
# IVERI_LITE_SHARED_SECRET=your-32-char-shared-secret
# IVERI_LITE_GATEWAY_URL=https://portal.nedsecure.co.za/Lite/Authorise.aspx
# Alternatives: https://portal.host.iveri.com/Lite/Authorise.aspx (hosted gateway)
#
# Out-of-band webhook (request enablement from assist@iveri.com):
# https://YOUR_PROJECT_REF.supabase.co/functions/v1/iveri-gateway?webhook=true
